# Real travel documents can contain private data. Keep binaries out of Git.
data/trips/*/pdfs/**
data/trips/*/documents/**
data/trips/*/qr/**
!data/trips/*/pdfs/.gitkeep
!data/trips/*/documents/.gitkeep
!data/trips/*/qr/.gitkeep

# Private ingestion area for real travel files. Never commit this.
.private/

# Import reports may include original filenames and hashes.
data/trips/*/document-review.json
data/trips/*/document-import-report.json
data/trips/*/document-index.json
